DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-prod"
PORT=4000

# Optional — enables the AI family update digest (POST /v1/families/:id/digest).
# Without this set, the feature returns a clear 503 and the rest of the app is unaffected.
ANTHROPIC_API_KEY=

# Optional — real payments. Use TEST MODE keys (no business verification needed).
# Razorpay: razorpay.com -> Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Stripe: stripe.com -> Dashboard -> Developers -> API keys (toggle "Test mode" on)
STRIPE_SECRET_KEY=

# Optional — real video check-ins. daily.co -> sign up -> Developers -> API keys
DAILY_API_KEY=

# Optional — error tracking. sentry.io -> create project -> copy DSN
SENTRY_DSN=

# WhatsApp Business API — needs Meta Business verification (days/weeks), so this
# stays unset/mocked until that's approved. See backend/src/lib/whatsapp.js.
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
