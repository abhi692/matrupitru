// MatruPitru — Phase 1 data model (see System Design doc §4)
// SQLite for local dev; swap provider to "postgresql" for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Family {
  id             String   @id @default(uuid())
  primaryBuyerId String
  billingCurrency String  @default("USD")
  consentAt      DateTime?
  createdAt      DateTime @default(now())

  users          User[]
  parents        Parent[]
  carePlan       CarePlan?
  bookings       ServiceBooking[]
  payments       Payment[]
  subscriptions  Subscription[]
  threads        Thread[]
  invites        FamilyInvite[]
}

// Lets a sibling join an existing family as a second (or third) buyer instead
// of MatruPitru only supporting one buyer per family — the single-buyer
// assumption didn't match how Indian families with multiple adult children
// actually share care responsibility.
model FamilyInvite {
  id          String   @id @default(uuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  phone       String
  invitedBy   String
  status      String   @default("pending") // pending | accepted | expired
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?
}

model User {
  id           String   @id @default(uuid())
  role         String   // buyer | parent | care_manager | caregiver | admin
  name         String
  phone        String   @unique
  email        String?
  passwordHash String
  locale       String   @default("en")
  timezone     String   @default("Asia/Kolkata")
  createdAt    DateTime @default(now())

  familyId     String?
  family       Family?  @relation(fields: [familyId], references: [id])

  // A device push token for real instant alerts (Expo Push service — works
  // without a separate Firebase/Apple developer account). One per user is
  // enough for Phase 1; a real multi-device app would need a join table.
  pushToken    String?

  parentProfile  Parent?    @relation("UserParentProfile")
  caregiverProfile Caregiver? @relation("UserCaregiverProfile")

  carePlansManaged CarePlan[] @relation("CareManagerPlans")
  visitsAssigned   Visit[]    @relation("CaregiverVisits")
  visitsScheduled  Visit[]    @relation("ScheduledByUser")
  alertsAcknowledged Alert[]  @relation("AlertAcknowledgedBy")
  messages         Message[]
  ratingsGiven     Rating[]   @relation("RatingByBuyer")
}

model Parent {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation("UserParentProfile", fields: [userId], references: [id])
  familyId         String
  family           Family   @relation(fields: [familyId], references: [id])

  dob              DateTime?
  address          String
  city             String?
  geoLat           Float?
  geoLng           Float?
  languagesJson    String   @default("[]")
  mobilityLevel    String   @default("independent")
  techComfort      String   @default("low")
  conditionsJson   String   @default("[]")
  allergiesJson    String   @default("[]")
  medicationsJson  String   @default("[]")
  emergencyContactsJson String @default("[]")
  preferredHospital String?
  notes            String?
  consentAt        DateTime?

  visits           Visit[]
  vitals           VitalsReading[]
  bookings         ServiceBooking[]
  alerts           Alert[]
  medicationLogs   MedicationLog[]
  medicationSchedules MedicationSchedule[]
}

// A recurring reminder set once by the buyer/Care Manager — e.g. "Amlodipine,
// daily at 08:00 and 20:00". The scheduler (src/scheduler/medication.js) reads
// active schedules and auto-generates each day's MedicationLog rows; nobody
// re-enters anything daily.
model MedicationSchedule {
  id            String   @id @default(uuid())
  parentId      String
  parent        Parent   @relation(fields: [parentId], references: [id])
  medication    String
  timesOfDayJson String  @default("[]") // ["08:00","20:00"]
  gracePeriodMinutes Int @default(15)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  logs          MedicationLog[]
}

model MedicationLog {
  id          String   @id @default(uuid())
  parentId    String
  parent      Parent   @relation(fields: [parentId], references: [id])
  scheduleId  String?
  schedule    MedicationSchedule? @relation(fields: [scheduleId], references: [id])
  medication  String
  scheduledAt DateTime
  status      String   @default("pending") // pending | due | given | missed
  firedAt     DateTime?
  givenAt     DateTime?
  recordedBy  String?

  @@unique([scheduleId, scheduledAt])
}

model CarePlan {
  id               String   @id @default(uuid())
  familyId         String   @unique
  family           Family   @relation(fields: [familyId], references: [id])
  tier             String   // basic | standard | premium_nri
  recurringServicesJson String @default("[]")
  careManagerId    String?
  careManager      User?    @relation("CareManagerPlans", fields: [careManagerId], references: [id])
  startDate        DateTime @default(now())
  status           String   @default("active")
}

model Visit {
  id            String   @id @default(uuid())
  parentId      String
  parent        Parent   @relation(fields: [parentId], references: [id])
  caregiverId   String?
  caregiver     User?    @relation("CaregiverVisits", fields: [caregiverId], references: [id])
  scheduledById String?
  scheduledBy   User?    @relation("ScheduledByUser", fields: [scheduledById], references: [id])

  type          String   // attendant | nurse | doctor | physio | errand
  scheduledAt   DateTime
  status        String   @default("scheduled") // scheduled|enroute|in_progress|completed|missed|cancelled

  checkInAt     DateTime?
  checkInGeoLat Float?
  checkInGeoLng Float?
  checkOutAt    DateTime?
  checkOutGeoLat Float?
  checkOutGeoLng Float?

  taskChecklistJson String @default("[]")
  notes         String?

  geoVerified   Boolean  @default(false)
  parentConfirmedAt DateTime?

  idempotencyKey String? @unique

  proofs        ProofArtifact[]
  vitals        VitalsReading[]

  createdAt     DateTime @default(now())
}

model ProofArtifact {
  id          String   @id @default(uuid())
  visitId     String
  visit       Visit    @relation(fields: [visitId], references: [id])
  type        String   // photo | vitals | signature | parent_confirmation
  storageUrl  String
  capturedAt  DateTime @default(now())
  capturedBy  String
  metadataJson String  @default("{}")
}

// Logically a time-series table — §4 explicitly warns against jamming vitals into
// the main transactional store as volume grows. Phase 1 keeps it in SQLite/Postgres
// behind this same model+API shape for simplicity; the (parentId, type, recordedAt)
// index below is what makes the trend query in health/routes.js cheap at this scale.
// Production swap path: point this model at a real time-series store (Timescale
// hypertable on this same table, or a separate InfluxDB/Timescale instance synced
// via the event bus) without changing the GET /v1/parents/:id/vitals contract.
model VitalsReading {
  id         String   @id @default(uuid())
  parentId   String
  parent     Parent   @relation(fields: [parentId], references: [id])
  visitId    String?
  visit      Visit?   @relation(fields: [visitId], references: [id])
  type       String   // bp | sugar | spo2 | weight | temp | pulse
  value      String
  unit       String
  recordedAt DateTime @default(now())
  source     String   // caregiver | device | self
  flagged    Boolean  @default(false)

  @@index([parentId, type, recordedAt])
}

model ServiceBooking {
  id            String   @id @default(uuid())
  familyId      String
  family        Family   @relation(fields: [familyId], references: [id])
  parentId      String
  parent        Parent   @relation(fields: [parentId], references: [id])
  serviceCatalogId String
  vendorId      String?
  status        String   @default("requested")
  scheduledAt   DateTime?
  price         Float
  currency      String   @default("INR")
  paymentId     String?
  idempotencyKey String? @unique
  createdAt     DateTime @default(now())
}

model Alert {
  id             String   @id @default(uuid())
  parentId       String
  parent         Parent   @relation(fields: [parentId], references: [id])
  severity       String   // info | warning | critical | emergency
  type           String   // missed_visit | vitals_out_of_range | sos | med_missed
  triggeredAt    DateTime @default(now())
  acknowledgedById String?
  acknowledgedBy User?    @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])
  acknowledgedAt DateTime?
  resolution     String?

  // Escalation tree (§6.2 had no fallback layer — this is that fallback).
  // escalationLevel 0 = just buyer+CM notified; each unacknowledged tick of
  // the scheduler bumps this and notifies the next emergency contact in line.
  escalationLevel Int     @default(0)
  lastEscalatedAt DateTime?
}

model Payment {
  id          String   @id @default(uuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  amount      Float
  currency    String
  method      String
  gatewayRef  String?
  provider    String?  // razorpay | stripe — null means still-mocked
  providerOrderId String?
  providerPaymentId String?
  type        String   // subscription | one_time
  status      String   @default("succeeded") // succeeded | pending | failed
  idempotencyKey String? @unique
  createdAt   DateTime @default(now())
}

// A Daily.co video room, created on demand for a "see your parent" check-in
// rather than just a text/photo proof of care — the highest-emotional-ROI
// gap identified for an elder-care product aimed at remote adult children.
model VideoSession {
  id         String   @id @default(uuid())
  familyId   String
  visitId    String?
  roomName   String
  roomUrl    String
  createdBy  String
  createdAt  DateTime @default(now())
  expiresAt  DateTime?
}

model Subscription {
  id          String   @id @default(uuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id])
  amount      Float
  currency    String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("active")
  idempotencyKey String? @unique
}

model Caregiver {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation("UserCaregiverProfile", fields: [userId], references: [id])
  verificationStatus String   @default("pending")
  skillsJson         String   @default("[]")
  serviceCitiesJson  String   @default("[]")
  rating             Float    @default(0)
  ratingCount        Int      @default(0)
  backgroundCheckRef String?
  availability       String   @default("available")

  documents          CaregiverDocument[]
  ratings            Rating[]
}

// Real verification pipeline instead of an admin just flipping a status flag —
// police verification / ID proof / reference letters get uploaded and
// individually reviewed, the way the trust signal actually works in India.
model CaregiverDocument {
  id           String   @id @default(uuid())
  caregiverId  String
  caregiver    Caregiver @relation(fields: [caregiverId], references: [id])
  type         String   // police_verification | id_proof | reference_letter | training_certificate
  fileUrl      String
  status       String   @default("pending") // pending | approved | rejected
  uploadedAt   DateTime @default(now())
  reviewedById String?
  reviewedAt   DateTime?
  notes        String?
}

// Buyer rates a caregiver after a completed visit. Feeds the caregiver's
// aggregate rating shown to Care Managers when assigning future visits.
model Rating {
  id          String   @id @default(uuid())
  visitId     String   @unique
  caregiverId String
  caregiver   Caregiver @relation(fields: [caregiverId], references: [id])
  buyerId     String
  buyer       User     @relation("RatingByBuyer", fields: [buyerId], references: [id])
  stars       Int
  comment     String?
  createdAt   DateTime @default(now())
}

model Thread {
  id        String   @id @default(uuid())
  familyId  String
  family    Family   @relation(fields: [familyId], references: [id])
  messages  Message[]
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  type      String   // visit.completed | vitals.recorded | sos.raised ...
  payloadJson String
  createdAt DateTime @default(now())
}
