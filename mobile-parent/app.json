{
  "expo": {
    "name": "MatruPitru",
    "slug": "matrupitru",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSLocationWhenInUseUsageDescription": "Caregivers use your location to geo-verify visit check-in/out against the parent's home address.",
        "NSCameraUsageDescription": "Caregivers use the camera to capture proof-of-care photos during visits."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "ACCESS_FINE_LOCATION",
        "CAMERA"
      ],
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1d9e75"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Caregivers use your location to geo-verify visit check-in/out."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Caregivers use the camera to capture proof-of-care photos."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
